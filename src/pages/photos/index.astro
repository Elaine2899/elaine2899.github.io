---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import photosData from '../../data/photos.json';

const images = import.meta.glob<{ default: ImageMetadata }>('../../assets/photos/*.webp', {
    eager: true,
});

const photos = photosData.map((p) => {
    const mod = images[`../../assets/photos/${p.file}.webp`];
    if (!mod) throw new Error(`photos.json 指到不存在的圖檔：${p.file}`);
    return { ...p, img: mod.default };
});
---

<Base title="攝影｜曾芸儀" description="曾芸儀的攝影紀錄。">
    <h1 class="page-title">攝影</h1>
    <p class="wip-note">內容整理中——目前為佔位示意圖，之後會換上照片。</p>

    <div class="photo-grid">
        {photos.map((p) => (
            <figure class="photo-item">
                <Image src={p.img} alt={p.title} widths={[480, 800, 1200]} sizes="(max-width: 640px) 100vw, 340px" loading="lazy" />
                <figcaption>{p.title}</figcaption>
            </figure>
        ))}
    </div>
</Base>

<style>
    .page-title {
        margin: 4rem 0 0;
        font-size: 1.6rem;
    }

    .photo-grid {
        margin-top: 2.5rem;
        columns: 2;
        column-gap: 1rem;
    }

    @media (max-width: 640px) {
        .photo-grid {
            columns: 1;
        }
    }

    .photo-item {
        margin: 0 0 1rem;
        break-inside: avoid;
    }

    .photo-item img {
        border-radius: 8px;
        border: 1px solid var(--border-color);
    }

    .photo-item figcaption {
        margin-top: 0.4rem;
        color: var(--text-muted);
        font-size: 0.8rem;
    }
</style>
