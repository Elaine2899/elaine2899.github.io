---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const notes = (await getCollection('notes')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) => d.toISOString().slice(0, 10);
---

<Base title="文字｜曾芸儀" description="曾芸儀的讀書、觀影與技術筆記。">
    <h1 class="page-title">文字</h1>
    <p class="wip-note">內容整理中——目前為佔位文章，之後會換上真正的筆記。</p>

    <ul class="note-list">
        {notes.map((note) => (
            <li>
                <a class="note-row" href={`/notes/${note.id}/`}>
                    <time datetime={fmt(note.data.date)}>{fmt(note.data.date)}</time>
                    <span class="note-title">{note.data.title}</span>
                    <span class="note-tags">
                        {note.data.tags.map((t) => <span class="tag">{t}</span>)}
                    </span>
                </a>
            </li>
        ))}
    </ul>
</Base>

<style>
    .page-title {
        margin: 4rem 0 0;
        font-size: 1.6rem;
    }

    .note-list {
        margin: 2.5rem 0 0;
        padding: 0;
        list-style: none;
    }

    .note-row {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        padding: 0.9rem 0;
        border-bottom: 1px solid var(--border-color);
        color: inherit;
    }

    .note-row:hover {
        text-decoration: none;
        color: inherit;
    }

    .note-row:hover .note-title {
        color: var(--accent-gold);
    }

    .note-row time {
        flex-shrink: 0;
        color: var(--text-muted);
        font-size: 0.85rem;
        font-variant-numeric: tabular-nums;
    }

    .note-title {
        transition: color 0.15s ease;
    }

    .note-tags {
        margin-left: auto;
        flex-shrink: 0;
        display: flex;
        gap: 0.4rem;
    }

    .tag {
        color: var(--text-muted);
        font-size: 0.78rem;
        border: 1px solid var(--border-color);
        border-radius: 999px;
        padding: 0.05rem 0.55rem;
    }

    @media (max-width: 640px) {
        .note-row {
            flex-wrap: wrap;
            gap: 0.3rem 1rem;
        }

        .note-title {
            width: 100%;
            order: -1;
        }
    }
</style>
